<Window x:Class="APP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:APP"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="1100">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition Height ="0.5*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Image x:Name="OriginImage" Grid.Row="0" Grid.Column="0" Grid.RowSpan="3" Grid.ColumnSpan="3"  Stretch="Uniform" />
        <Image x:Name="GridImage" Grid.Row="0" Grid.Column="3" Grid.RowSpan="3" Grid.ColumnSpan="3"  Stretch="Uniform" />
        <Image x:Name="ConvertImage" Grid.Row="0" Grid.Column="6" Grid.RowSpan="3" Grid.ColumnSpan="3"  Stretch="Uniform" />
        <Button Name="btnLoadImage"  Grid.Row="0" Grid.Column="9" Margin="5" FontSize="20" Click="btnLoadImage_Click">Load</Button>
        <Button Name="btnTest"  Grid.Row="0" Grid.Column="10" Margin="5" FontSize="20" Click="btnConvert_Click">테스트</Button>

        <Button Name="btnMultitest"  Grid.Row="2" Grid.Column="9"  Grid.ColumnSpan="2" Margin="5" FontSize="20" Click="btnMultiteste_Click">MultiTest</Button>

        <TextBox x:Name="Result" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="30"></TextBox>
        <Label Grid.Row="4" Grid.Column="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20">결 과 :</Label>

        <Label Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20">Origin Imgae</Label>
        <Label Grid.Row="3" Grid.Column="3" Grid.ColumnSpan="3" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20">Grid Image</Label>
        <Label Grid.Row="3" Grid.Column="6" Grid.ColumnSpan="3" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20">Covert Image</Label>

        <TextBox Grid.Row="1" Grid.Column="10" x:Name="Resolution" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="20">5.5</TextBox>
        <Label Grid.Row="1" Grid.Column="9" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="18">Resolution</Label>
    </Grid>
</Window>
